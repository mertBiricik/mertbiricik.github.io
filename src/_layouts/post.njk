---
layout: base
---

<section class="section">
  <div class="container-narrow">
    <a href="/blog/" class="inline-flex items-center gap-2 text-sm text-ink-500 hover:text-brand-700 dark:text-ink-400 dark:hover:text-brand-300 mb-8">
      <i class="fa-solid fa-arrow-left text-xs"></i> Back to blog
    </a>

    <article>
      <header class="mb-10 border-b border-ink-200 pb-8 dark:border-ink-800">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-ink-900 dark:text-white">{{ title }}</h1>
        <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink-500 dark:text-ink-400">
          {% if date %}
          <span class="inline-flex items-center gap-2"><i class="fa-regular fa-calendar"></i> {{ date | dateFormat }}</span>
          {% endif %}
          {% if author %}
          <span class="inline-flex items-center gap-2"><i class="fa-regular fa-user"></i> {{ author }}</span>
          {% endif %}
        </div>
        {% if tags %}
        <div class="mt-4 flex flex-wrap gap-2">
          {% for tag in tags %}<span class="chip-brand">{{ tag }}</span>{% endfor %}
        </div>
        {% endif %}
      </header>

      <div class="prose prose-lg dark:prose-invert max-w-none prose-headings:scroll-mt-24 prose-a:font-medium prose-pre:rounded-xl">
        {{ content | safe }}
      </div>
    </article>
  </div>
</section>
