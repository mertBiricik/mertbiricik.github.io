<!DOCTYPE html>
<html lang="en">
<head>
  <script>
    (function() {
      try {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        if (theme === 'dark') document.documentElement.classList.add('dark');
      } catch (e) {}
    })();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} · {% endif %}{{ metadata.title }} — {{ metadata.tagline }}</title>
  <meta name="description" content="{{ description or metadata.description }}">

  <meta name="google-site-verification" content="0b64d5c9758fafd9">

  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
  <meta property="og:title" content="{% if title %}{{ title }} · {% endif %}{{ metadata.title }}">
  <meta property="og:description" content="{{ description or metadata.description }}">
  <meta property="og:site_name" content="{{ metadata.title }}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{% if title %}{{ title }} · {% endif %}{{ metadata.title }}">
  <meta name="twitter:description" content="{{ description or metadata.description }}">

  <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">

  <link rel="icon" type="image/svg+xml" href="/assets/icons/icon.svg">
  <link rel="manifest" href="/assets/icons/site.webmanifest">
  <meta name="theme-color" content="#0a0a08">
  <link rel="alternate" href="/rss.xml" type="application/atom+xml" title="{{ metadata.title }} — Feed">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=JetBrains+Mono:wght@400;500;700&family=UnifrakturMaguntia&display=swap">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 focus:bg-ink-900 focus:text-bone-50 focus:px-3 focus:py-2 focus:no-underline">Skip to content</a>

  {# ============= MASTHEAD ============= #}
  <header id="site-header" class="border-b-2 border-ink-900 dark:border-bone-100">
    <div class="container-wide">
      <div class="flex items-center justify-between py-3 text-[11px] font-mono uppercase tracking-[0.22em] text-ink-700 dark:text-bone-300 border-b border-ink-900 dark:border-bone-200">
        <span>Vol. {{ site.buildYear }} &nbsp;·&nbsp; No. {{ site.buildVersion }}</span>
        <span class="hidden sm:inline">{{ profile.location }}</span>
        <span>Established <time datetime="2021">MMXXI</time></span>
      </div>

      <div class="py-6 sm:py-8 flex flex-col items-center text-center">
        <a href="/" class="no-underline">
          <h1 class="font-blackletter text-ink-900 dark:text-bone-50 leading-none text-5xl sm:text-7xl lg:text-8xl">Mert Biricik</h1>
        </a>
        <p class="mt-2 font-mono text-[10px] sm:text-xs uppercase tracking-[0.4em] text-blood-700 dark:text-blood-400">
          ✠ &nbsp; {{ metadata.tagline }} &nbsp; ✠
        </p>
      </div>

      <nav class="border-t-2 border-ink-900 dark:border-bone-100">
        <div class="flex items-center justify-between gap-4 py-3">
          <ul id="nav-menu" class="hidden md:flex items-center gap-7">
            {% for item in navigation %}
            <li>
              <a href="{{ item.url }}" class="nav-link {% if page.url == item.url %}active{% endif %}">
                <span class="mr-1 text-blood-700 dark:text-blood-400">§</span>{{ item.text }}
              </a>
            </li>
            {% endfor %}
          </ul>

          <div class="flex items-center gap-2 ml-auto">
            <a href="{{ metadata.social.github }}" target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex h-9 w-9 items-center justify-center border border-ink-900 dark:border-bone-100 text-ink-900 dark:text-bone-50 hover:bg-ink-900 hover:text-bone-50 dark:hover:bg-bone-50 dark:hover:text-ink-900 transition-colors no-underline" aria-label="GitHub">
              <i class="fa-brands fa-github text-sm"></i>
            </a>
            <a href="{{ metadata.social.scholar }}" target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex h-9 w-9 items-center justify-center border border-ink-900 dark:border-bone-100 text-ink-900 dark:text-bone-50 hover:bg-ink-900 hover:text-bone-50 dark:hover:bg-bone-50 dark:hover:text-ink-900 transition-colors no-underline" aria-label="Google Scholar">
              <i class="fa-solid fa-graduation-cap text-sm"></i>
            </a>
            <button id="theme-toggle" class="inline-flex h-9 w-9 items-center justify-center border border-ink-900 dark:border-bone-100 text-ink-900 dark:text-bone-50 hover:bg-ink-900 hover:text-bone-50 dark:hover:bg-bone-50 dark:hover:text-ink-900 transition-colors" aria-label="Toggle theme">
              <i class="fa-solid fa-sun sun-icon text-sm"></i>
              <i class="fa-solid fa-moon moon-icon text-sm"></i>
            </button>
            <button id="menu-toggle" class="md:hidden inline-flex h-9 w-9 items-center justify-center border border-ink-900 dark:border-bone-100 text-ink-900 dark:text-bone-50 hover:bg-ink-900 hover:text-bone-50 dark:hover:bg-bone-50 dark:hover:text-ink-900 transition-colors" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
              <i class="fa-solid fa-bars text-sm"></i>
            </button>
          </div>
        </div>
      </nav>

      <div id="mobile-menu" class="md:hidden hidden border-t-2 border-ink-900 dark:border-bone-100">
        <ul class="py-3 space-y-2">
          {% for item in navigation %}
          <li>
            <a href="{{ item.url }}" class="nav-link block py-1 {% if page.url == item.url %}active{% endif %}">
              <span class="mr-1 text-blood-700 dark:text-blood-400">§</span>{{ item.text }}
            </a>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </header>

  <main id="main" class="flex-1">
    {{ content | safe }}
  </main>

  {# ============= FOOTER ============= #}
  <footer class="mt-auto border-t-2 border-ink-900 dark:border-bone-100">
    <div class="container-wide py-12">
      <div class="grid gap-10 md:grid-cols-12">
        <div class="md:col-span-5">
          <p class="eyebrow-blood">Colophon</p>
          <p class="mt-3 font-serif text-base leading-relaxed text-ink-700 dark:text-bone-200">
            Set in <span class="font-display italic">Cormorant Garamond</span> and <span class="font-serif italic">EB Garamond</span>; ornaments in <span class="font-blackletter">UnifrakturMaguntia</span>; labels in <span class="font-mono">JetBrains Mono</span>. Composed in Eleventy, hand-set with Tailwind. Pressed at GitHub Pages, Berlin–Istanbul.
          </p>
        </div>

        <div class="md:col-span-3">
          <p class="eyebrow">Correspondence</p>
          <ul class="mt-3 space-y-1.5 font-mono text-xs uppercase tracking-[0.16em]">
            <li><a href="{{ metadata.social.email }}" class="no-underline hover:underline">mert@biricik.de</a></li>
            <li><a href="{{ metadata.social.linkedin }}" target="_blank" rel="noopener noreferrer" class="no-underline hover:underline">linkedin / mertbiricik</a></li>
            <li><a href="{{ metadata.social.github }}" target="_blank" rel="noopener noreferrer" class="no-underline hover:underline">github / mertBiricik</a></li>
            <li><a href="{{ metadata.social.scholar }}" target="_blank" rel="noopener noreferrer" class="no-underline hover:underline">google scholar</a></li>
            <li><a href="/rss.xml" class="no-underline hover:underline">rss feed</a></li>
          </ul>
        </div>

        <div class="md:col-span-4">
          <p class="eyebrow">Index</p>
          <ul class="mt-3 grid grid-cols-2 gap-y-1.5 font-mono text-xs uppercase tracking-[0.16em]">
            {% for item in navigation %}
            <li><a href="{{ item.url }}" class="no-underline hover:underline">{{ item.text }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </div>

      <div class="mt-10 pt-6 border-t-2 border-ink-900 dark:border-bone-100 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[10px] uppercase tracking-[0.22em] text-ink-500 dark:text-bone-300">
        <p>© Anno Domini {{ site.buildYear }} · Mert Biricik · All rights reserved</p>
        <p>Memento mori &nbsp;✠&nbsp; Memento codere</p>
      </div>
    </div>
  </footer>

  <script src="/js/main.js" defer></script>
</body>
</html>
