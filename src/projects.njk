---
layout: base
title: Projects
description: Selected research and engineering projects in cybersecurity, applied AI, energy data, and systems programming.
priority: 0.9
changefreq: monthly
---

<section class="section pt-16 lg:pt-20">
  <div class="container-wide">
    <p class="section-eyebrow">Portfolio</p>
    <h1 class="mt-2 text-4xl sm:text-5xl font-bold text-ink-900 dark:text-white">Projects</h1>
    <p class="mt-3 max-w-2xl text-lg text-ink-600 dark:text-ink-300">
      Research-grade systems and tooling spanning cybersecurity, AI agents, energy data, BCI signal processing, and low-level systems programming.
    </p>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {% for project in projects.all %}
      <article class="card flex flex-col h-full">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="text-xl font-semibold text-ink-900 dark:text-white">{{ project.title }}</h3>
            {% if project.subtitle %}<p class="mt-1 text-sm text-ink-500 dark:text-ink-400">{{ project.subtitle }}</p>{% endif %}
          </div>
          {% if project.period %}<span class="chip shrink-0">{{ project.period }}</span>{% endif %}
        </div>

        <dl class="mt-5 space-y-3 text-sm">
          <div>
            <dt class="font-semibold text-ink-800 dark:text-ink-200">Problem</dt>
            <dd class="text-ink-600 dark:text-ink-400">{{ project.problem }}</dd>
          </div>
          <div>
            <dt class="font-semibold text-ink-800 dark:text-ink-200">Solution</dt>
            <dd class="text-ink-600 dark:text-ink-400">{{ project.solution }}</dd>
          </div>
          <div>
            <dt class="font-semibold text-ink-800 dark:text-ink-200">Outcome</dt>
            <dd class="text-ink-600 dark:text-ink-400">{{ project.outcome }}</dd>
          </div>
        </dl>

        {% if project.tech %}
        <ul class="mt-5 flex flex-wrap gap-2">
          {% for t in project.tech %}<li class="chip-brand">{{ t }}</li>{% endfor %}
        </ul>
        {% endif %}

        <div class="mt-6 flex flex-wrap gap-2 pt-5 border-t border-ink-200 dark:border-ink-800">
          {% if project.sourceLink %}<a href="{{ project.sourceLink }}" target="_blank" rel="noopener noreferrer" class="btn-outline btn-sm"><i class="fa-brands fa-github"></i> Code</a>{% endif %}
          {% if project.visitSiteLink %}<a href="{{ project.visitSiteLink }}" target="_blank" rel="noopener noreferrer" class="btn-primary btn-sm"><i class="fa-solid fa-up-right-from-square"></i> Live</a>{% endif %}
          {% if project.demoLink %}<a href="{{ project.demoLink }}" class="btn-outline btn-sm"><i class="fa-solid fa-chart-bar"></i> Demo</a>{% endif %}
          {% if project.publicationLink %}<a href="{{ project.publicationLink }}" target="_blank" rel="noopener noreferrer" class="btn-outline btn-sm"><i class="fa-solid fa-file-lines"></i> Paper</a>{% endif %}
        </div>
      </article>
      {% endfor %}
    </div>

    <div class="mt-16 text-center">
      <h2 class="text-2xl font-semibold text-ink-900 dark:text-white">Looking for a collaborator?</h2>
      <p class="mt-2 text-ink-600 dark:text-ink-300">Open to research collaborations and applied cybersecurity / AI engineering roles.</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <a href="/contact/" class="btn-primary"><i class="fa-solid fa-envelope"></i> Contact</a>
        <a href="{{ metadata.social.github }}" target="_blank" rel="noopener noreferrer" class="btn-outline"><i class="fa-brands fa-github"></i> See my GitHub</a>
      </div>
    </div>
  </div>
</section>
