---
layout: base
title: Blog
description: Long-form notes on cybersecurity research, applied AI, RAG systems, and infrastructure work.
priority: 0.7
changefreq: monthly
---

<section class="container-wide pt-12 sm:pt-16 lg:pt-20 pb-10">
  <div class="max-w-3xl">
    <p class="eyebrow-blood">Blog</p>
    <h1 class="display-1 mt-5 text-ink-900 dark:text-bone-50 text-balance">Notes from the lab.</h1>
    <p class="mt-6 font-sans text-xl text-ink-700 dark:text-bone-200 leading-relaxed">
      Long-form posts on cybersecurity, retrieval-augmented generation, infrastructure, and the messy bits in between.
    </p>
  </div>
</section>

<section class="container-wide section-tight">
  <ol class="border-t-2 border-ink-900 dark:border-bone-100">
    {% for post in collections.blog | reverse %}
    <article class="grid md:grid-cols-12 gap-6 py-10 border-b-2 border-ink-900 dark:border-bone-100">
      <div class="md:col-span-3">
        <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-blood-700 dark:text-blood-400">{{ post.date | dateFormat }}</p>
        <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.18em] text-ink-500 dark:text-bone-300">№ {{ loop.index | pad }}</p>
      </div>

      <div class="md:col-span-9">
        <h3 class="font-display text-3xl sm:text-4xl leading-tight text-ink-900 dark:text-bone-50">
          <a href="{{ post.url }}" class="no-underline hover:underline">{{ post.data.title }}</a>
        </h3>
        {% if post.data.description %}
        <p class="mt-3 font-sans text-base sm:text-lg text-ink-700 dark:text-bone-200 leading-relaxed">{{ post.data.description }}</p>
        {% endif %}

        <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2">
          {% if post.data.tags %}
          <ul class="flex flex-wrap gap-1.5">
            {% for tag in post.data.tags %}<li class="tag">{{ tag }}</li>{% endfor %}
          </ul>
          {% endif %}
          <a href="{{ post.url }}" class="font-mono text-[11px] uppercase tracking-[0.2em] no-underline hover:underline ml-auto">→ Read full post</a>
        </div>
      </div>
    </article>
    {% endfor %}
  </ol>

  {% if not collections.blog.length %}
  <div class="text-center py-16">
    <p class="font-display text-2xl text-ink-700 dark:text-bone-300">No posts yet.</p>
    <p class="mt-3 font-sans text-ink-500 dark:text-bone-400">Check back soon.</p>
  </div>
  {% endif %}
</section>
